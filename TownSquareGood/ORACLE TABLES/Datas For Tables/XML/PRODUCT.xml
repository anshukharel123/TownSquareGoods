CREATE TABLE  "PRODUCT" 
   (	"PRODUCT_ID" NUMBER(5,0), 
	"PRODUCT_NAME" VARCHAR2(40) NOT NULL ENABLE, 
	"PRODUCT_DESCRIPTION" VARCHAR2(150), 
	"PRODUCT_IMAGE" VARCHAR2(255), 
	"QUANTITY_IN_STOCK" NUMBER(5,0), 
	"PRICE" NUMBER(8,2), 
	"IS_DISABLED" VARCHAR2(6), 
	"UNIT" VARCHAR2(10), 
	"ALERGYINFORMATION" VARCHAR2(250), 
	"SHOP_ID" NUMBER(5,0), 
	 PRIMARY KEY ("PRODUCT_ID") ENABLE, 
	 UNIQUE ("PRODUCT_NAME") ENABLE
   )
/
ALTER TABLE  "PRODUCT" ADD FOREIGN KEY ("SHOP_ID")
	  REFERENCES  "SHOP" ("SHOP_ID") ENABLE
/

CREATE OR REPLACE TRIGGER  "PRODUCT_TRIGGER" 
BEFORE INSERT ON PRODUCT 
FOR EACH ROW 
BEGIN 
    IF :NEW.product_id IS NULL THEN 
        :NEW.product_id := product_seq.NEXTVAL; 
    END IF; 
END; 

/
ALTER TRIGGER  "PRODUCT_TRIGGER" ENABLE
/