CREATE TABLE  "WISHLIST" 
   (	"WISHLIST_ID" NUMBER(5,0), 
	"ADDED_AT" DATE, 
	"USER_ID" NUMBER(5,0), 
	"PRODUCT_ID" NUMBER(5,0), 
	 PRIMARY KEY ("WISHLIST_ID") ENABLE
   )
/
ALTER TABLE  "WISHLIST" ADD FOREIGN KEY ("USER_ID")
	  REFERENCES  "USERS" ("USER_ID") ENABLE
/
ALTER TABLE  "WISHLIST" ADD FOREIGN KEY ("PRODUCT_ID")
	  REFERENCES  "PRODUCT" ("PRODUCT_ID") ENABLE
/

CREATE OR REPLACE TRIGGER  "WISHLIST_TRIGGER" 
BEFORE INSERT ON WISHLIST 
FOR EACH ROW 
BEGIN 
    IF :NEW.wishlist_id IS NULL THEN 
        :NEW.wishlist_id := wishlist_seq.NEXTVAL; 
    END IF; 
END; 

/
ALTER TRIGGER  "WISHLIST_TRIGGER" ENABLE
/
