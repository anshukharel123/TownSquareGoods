CREATE TABLE  "REVIEW" 
   (	"REVIEW_ID" NUMBER(5,0), 
	"MESSAGE" VARCHAR2(150), 
	"NO_OF_STARS" NUMBER(5,0) NOT NULL ENABLE, 
	"PRODUCT_ID" NUMBER(5,0), 
	"USER_ID" NUMBER(5,0), 
	 PRIMARY KEY ("REVIEW_ID") ENABLE
   )
/
ALTER TABLE  "REVIEW" ADD FOREIGN KEY ("PRODUCT_ID")
	  REFERENCES  "PRODUCT" ("PRODUCT_ID") ENABLE
/
ALTER TABLE  "REVIEW" ADD FOREIGN KEY ("USER_ID")
	  REFERENCES  "USERS" ("USER_ID") ENABLE
/

CREATE OR REPLACE TRIGGER  "REVIEW_TRIGGER" 
BEFORE INSERT ON REVIEW 
FOR EACH ROW 
BEGIN 
    IF :NEW.review_id IS NULL THEN 
        :NEW.review_id := review_seq.NEXTVAL; 
    END IF; 
END; 

/
ALTER TRIGGER  "REVIEW_TRIGGER" ENABLE
/
